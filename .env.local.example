# Supabase — get from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Resend — get from resend.com → API Keys
RESEND_API_KEY=re_your_key_here

# Notification recipients (manager + secretary emails)
NOTIFY_EMAIL_1=manager@email.com
NOTIFY_EMAIL_2=secretary@email.com

# Your deployed Vercel URL (use http://localhost:3000 for local dev)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
